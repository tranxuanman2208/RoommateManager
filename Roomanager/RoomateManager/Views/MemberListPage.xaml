<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      x:Class="RoommateManager.Views.MemberListPage"
      Title="Danh sách thành viên"
      Background="#F5F5F5"
      d:DesignHeight="454.442"
      d:DesignWidth="401.934">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

		
        <!-- Header -->
        <Border Grid.Row="0" Background="#1976D2">
            <Grid Margin="16,0">
                <TextBlock Text="Danh sách thành viên"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <!-- Nút thêm + thông báo -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnAddMember" Content="+ Thêm"
                            Background="White" Foreground="#1976D2"
							
                            BorderThickness="0" Padding="12,6"
                            FontWeight="Bold" Click="BtnAddMember_Click"
                            Margin="0,0,5,0"/>

                    <Button x:Name="btnNotification" Content="🔔 Thông báo"
                            Background="White" Foreground="#1976D2"
                            BorderThickness="0" Padding="12,6"
                            FontWeight="Bold" Click="BtnNotification_Click"/>

                    <!-- Popup thông báo -->
                    <Popup x:Name="NotificationPopup"
                           PlacementTarget="{Binding ElementName=btnNotification}"
                           Placement="Bottom"
                           StaysOpen="False">
                        <Border Background="White" CornerRadius="8" Padding="12" Width="300">
                            <StackPanel>
                                <TextBlock Text="Thông báo" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                                <!-- Item 1 -->
                                <Border Background="#FAFAFA" CornerRadius="6" Padding="8" Margin="0,4">
                                    <StackPanel>
                                        <TextBlock Text="Nội dung: Đã đến hạn thanh toán tiền thuê phòng" FontWeight="Bold"/>
                                        <TextBlock Text="Người gửi: Chủ phòng trọ" Foreground="Gray"/>
                                        <TextBlock Text="Thời gian: 01/03/2026" Foreground="DarkGray" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- Item 2 -->
                                <Border Background="#FAFAFA" CornerRadius="6" Padding="8" Margin="0,4">
                                    <StackPanel>
                                        <TextBlock Text="Nội dung: Phụ thu tiền điện" FontWeight="Bold"/>
                                        <TextBlock Text="Người gửi: Chủ phòng trọ" Foreground="Gray"/>
                                        <TextBlock Text="Thời gian: 25/03/2026 19:21" Foreground="DarkGray" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                
                                
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Danh sách -->
        <ScrollViewer Grid.Row="1" Margin="12">
            <ItemsControl x:Name="MemberList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,6" Background="White" CornerRadius="12"
                                Padding="14" MouseRightButtonDown="MemberCard_RightClick">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="44" Height="44"
                                        CornerRadius="22" Background="#1976D2">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               Foreground="White" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Tên + vai trò -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding RoleDisplay}" FontSize="12" Foreground="#757575"/>
                                </StackPanel>

                                <!-- Trạng thái -->
                                <Border Grid.Column="2" CornerRadius="12" Padding="10,4"
                                        Background="{Binding StatusColor}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
   