<Page x:Class="RoomateManager.PhanCongPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RoomateManager"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PhanCongPage">

    <Page.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#95A5A6"/>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="TIẾN ĐỘ VỆ SINH TRONG TUẦN" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <Grid Margin="0,10,0,0">
                <ProgressBar Name="pgbTienDo" Height="20" Value="10" Maximum="100" Foreground="#27AE60" Background="#D5DBDB"/>
                <TextBlock Name="txtPhanTram" Text="10% Hoàn thành" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#2C3E50" FontWeight="Bold"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Thành viên (Xoay vòng)" Grid.Column="0" Margin="0,0,12,0" Padding="8" BorderBrush="#BDC3C7">
                <ListBox Name="lstThanhVien" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"/>
            </GroupBox>

            <GroupBox Header="Danh sách nhiệm vụ dọn dẹp" Grid.Column="1" Padding="8" BorderBrush="#BDC3C7" Margin="0,0,0,0">
                <ListView Name="lstNhiemVu" BorderThickness="0" Margin="8,0,8,0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsDone}" IsEnabled="False" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Nhiệm vụ" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding TaskName}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Tần suất" Width="90" DisplayMemberBinding="{Binding Frequency}" />
                            <GridViewColumn Header="Người thực hiện" Width="120" DisplayMemberBinding="{Binding AssignedMember}" />
                            <GridViewColumn Header="Trạng thái" Width="90" DisplayMemberBinding="{Binding Status}" />
                            <GridViewColumn Header="Minh chứng (File)" Width="120" DisplayMemberBinding="{Binding MinhChungFileName}" />
                            <GridViewColumn Header="Ngày nhắc tiếp theo" Width="140" DisplayMemberBinding="{Binding NextReminderDisplay}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Width="80" Height="80" CornerRadius="8" Background="#ECEFF1" Margin="8" ClipToBounds="True">
                    <Image Name="imgPreview" Stretch="UniformToFill"/>
                </Border>

                <Button Name="btnOpenAddTask" Click="btnOpenAddTask_Click" Style="{StaticResource SecondaryButton}" Margin="8,0" Content="＋ Thêm nhiệm vụ"/>
                <Button Name="btnUpload" Click="btnUpload_Click" Style="{StaticResource SecondaryButton}" Margin="8,0" Content="📷 Tải ảnh minh chứng"/>
                <Button Name="btnXemMinhChung" Click="btnXemMinhChung_Click" Style="{StaticResource SecondaryButton}" Margin="8,0" Content="🔍 Xem minh chứng"/>
                <Button Name="btnXacNhan" Click="btnXacNhan_Click" Style="{StaticResource PrimaryButton}" Margin="8,0" Content="✔ Xác nhận hoàn thành"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>