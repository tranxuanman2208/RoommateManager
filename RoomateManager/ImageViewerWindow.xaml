<Window x:Class="RoommateManager.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xem hình ảnh" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"       AllowsTransparency="True" Background="Transparent"
        KeyDown="Window_KeyDown"   MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
    </Window.Effect>

    <Grid Margin="20">
        <Border Background="White" CornerRadius="15" Padding="5">
            <Grid>
                <Image x:Name="imgFull" Stretch="Uniform"/>

                <Button Content="✕" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Width="30" Height="30"
                        Margin="10"
                        Background="#44000000" 
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>