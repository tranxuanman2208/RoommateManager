<Page x:Class="RoomateManager.Models.ThongKePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RoomateManager.Models"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Thống kê chi tiêu" Background="#F4F7F9">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="PHÂN TÍCH CHI TIÊU HÀNG THÁNG" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <Rectangle Height="3" Width="100" Fill="#E67E22" HorizontalAlignment="Left" Margin="0,5,0,20"/>

            <StackPanel Orientation="Horizontal">
                <Border Background="White" CornerRadius="5" Padding="10,5" BorderBrush="#DDD" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Chọn tháng: " VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbMonth" Width="120" Margin="10,0,0,0" 
                                  SelectionChanged="CmbMonth_SelectionChanged"
                                  BorderThickness="0" Background="Transparent">
                            <ComboBoxItem Content="Tháng 1"/>
                            <ComboBoxItem Content="Tháng 2"/>
                            <ComboBoxItem Content="Tháng 3"/>
                            <ComboBoxItem Content="Tháng 4" IsSelected="True"/>
                            <ComboBoxItem Content="Tháng 5"/>
                            <ComboBoxItem Content="Tháng 6"/>
                            <ComboBoxItem Content="Tháng 7"/>
                            <ComboBoxItem Content="Tháng 8"/>
                            <ComboBoxItem Content="Tháng 9"/>
                            <ComboBoxItem Content="Tháng 10"/>
                            <ComboBoxItem Content="Tháng 11"/>
                            <ComboBoxItem Content="Tháng 12"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="15" Padding="20" BorderBrush="#EEE" BorderThickness="1">
            <Grid>
                <lvc:PieChart x:Name="MyPieChart" 
                              LegendLocation="Right" 
                              Hoverable="True" 
                              InnerRadius="80">
                    <lvc:PieChart.ChartLegend>
                        <lvc:DefaultLegend BulletSize="20" Foreground="#2C3E50" FontSize="14"/>
                    </lvc:PieChart.ChartLegend>
                </lvc:PieChart>

                <TextBlock x:Name="TxtNoData" Text="Không có dữ liệu chi tiêu cho tháng này" 
                           VerticalAlignment="Center" HorizontalAlignment="Center" 
                           FontSize="16" Foreground="#95A5A6" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>