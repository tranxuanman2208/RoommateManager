<Page x:Class="RoommateManager.Views.VatDungPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      mc:Ignorable="d" 
      Title="Quản lý vật dụng"
      Background="#F0F2F5" d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DDE0E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="Black"/>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Quản lý vật dụng" FontSize="28" FontWeight="ExtraBold" Foreground="#1A1A1A"/>
            <Rectangle Height="4" Width="60" Fill="#2196F3" HorizontalAlignment="Left" Margin="2,5,0,0" RadiusX="2" RadiusY="2"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,20,-72" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="THÔNG TIN CHI TIẾT" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>

                    <TextBlock Text="Tên vật dụng" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtTen" Tag="Ví dụ: Máy lạnh"/>

                    <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtGhiChu" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>

                    <CheckBox x:Name="chkBaoDuong" Content="Đang trong quá trình bảo dưỡng" Margin="0,15,0,0" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Hình ảnh" Style="{StaticResource FieldLabel}"/>
                    <Button Content="📁 Chọn tệp ảnh" Click="ChooseImage_Click" Style="{StaticResource ModernButton}" Background="#ECEFF1" Foreground="#455A64" Margin="0,0,0,10"/>

                    <Border CornerRadius="8" BorderThickness="1" BorderBrush="#EEEEEE" Height="150" Background="#FAFAFA">
                        <Image x:Name="imgPreview" Stretch="Uniform"  Margin="5" MouseDown="ImagePreview_MouseDown"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="5" Effect="{StaticResource CardShadow}">
                <DataGrid x:Name="gridVatDung" 
                          AutoGenerateColumns="False" 
                          Background="Transparent" 
                          BorderThickness="0"
                          RowHeight="70"
                          GridLinesVisibility="None"
                          CanUserAddRows="False"
                          SelectionChanged="gridVatDung_SelectionChanged"
                          IsReadOnly="True"
                          HeadersVisibility="Column">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#7F8C8D"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F0F0F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TÊN VẬT DỤNG" Binding="{Binding Tenvd}" Width="*" ElementStyle="{StaticResource {x:Type TextBlock}}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="15,0"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="NGÀY TẠO" Binding="{Binding Ngaytao, StringFormat=dd/MM/yyyy}" Width="120"/>

                        <DataGridTemplateColumn Header="HÌNH ẢNH" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" ClipToBounds="True" Width="60" Height="50" Margin="5">
                                        <Image Source="{Binding Hinhanh}" Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="TRẠNG THÁI" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="15" Padding="12,5" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Baoduong}" Value="True">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Tốt"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Baoduong}" Value="True">
                                                            <Setter Property="Text" Value="Bảo trì"/>
                                                            <Setter Property="Foreground" Value="#EF6C00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnThem" Content="+ THÊM MỚI" Click="Add_Click" Style="{StaticResource ModernButton}" Background="#2ECC71" Foreground="White" Width="120" Margin="10,0"/>
            <Button x:Name="btnSua" Content="✏️ SỬA" Click="Update_Click" Style="{StaticResource ModernButton}" Background="#3498DB" Foreground="White" Width="120" Margin="0,0,10,0"/>
            <Button x:Name="btnXoa" Content="🗑 XÓA" Click="Delete_Click" Style="{StaticResource ModernButton}" Background="#E74C3C" Foreground="White" Width="100"/>
        </StackPanel>

    </Grid>
</Page>