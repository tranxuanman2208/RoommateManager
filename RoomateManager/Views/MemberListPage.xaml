<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="RoommateManager.Views.MemberListPage"
      Title="Danh sách thành viên" Background="#F5F5F5" d:DesignHeight="454.442" d:DesignWidth="401.934">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1976D2">
            <Grid Margin="16,0">
                <TextBlock Text="Danh sách thành viên"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <!-- Nút thêm + thông báo -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnAddMember" Content="+ Thêm"
                            Background="White" Foreground="#1976D2"
							
                            BorderThickness="0" Padding="12,6"
                            FontWeight="Bold" Click="BtnAddMember_Click"
                            Margin="0,0,5,0"/>

                    <Button x:Name="btnNotification" Content="🔔 Thông báo"
                            Background="White" Foreground="#1976D2"
                            BorderThickness="0" Padding="12,6"
                            FontWeight="Bold" Click="BtnNotification_Click"/>

                    <!-- Popup thông báo -->
                    <Popup x:Name="NotificationPopup"
       PlacementTarget="{Binding ElementName=btnNotification}"
       Placement="Bottom"
       StaysOpen="False"
       AllowsTransparency="True">
                        <Border Background="White" CornerRadius="12" Width="300" Height="370" 
            BorderBrush="#2196F3" BorderThickness="1" Margin="0,5,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.15"/>
                            </Border.Effect>

                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="THÔNG BÁO" FontWeight="Bold" Foreground="#2196F3" 
                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" 
                        BorderBrush="Transparent" FontSize="16" Foreground="#999" 
                        Cursor="Hand" Click="btn_ClosePopup_Click"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <ScrollViewer x:Name="scrViewStatus" Visibility="Visible">
                                        <ItemsControl x:Name="lstNotifications">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#F2F2F2" BorderThickness="0,0,0,1" Background="Transparent" Padding="10,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Noidung}" TextWrapping="Wrap" FontSize="13" Foreground="#444"/>
                                                                <TextBlock Text="{Binding Ngaytb}" FontSize="11" Foreground="#999" Margin="0,3,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding TyleDoc}" Foreground="#2196F3" 
                                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel x:Name="stkAddNotification" Visibility="Collapsed">
                                        <TextBlock Text="Nội dung" FontSize="12" Foreground="#888" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtInputTB" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                             Padding="8" BorderBrush="#EEE" BorderThickness="1" Margin="0,0,0,12"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Người gửi: " FontSize="12" Foreground="#888"/>
                                            <TextBlock Text="Admin" FontSize="12" FontWeight="Bold" Foreground="#333" Margin="5,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,20">
                                            <TextBlock Text="Người nhận:" FontSize="12" Foreground="#888" Margin="0,0,0,5"/>
                                            <ComboBox x:Name="cboRecipient" DisplayMemberPath="Ten" SelectedValuePath="Id" 
                                  Height="30" VerticalContentAlignment="Center"/>
                                        </StackPanel>

                                        <Button Content="XÁC NHẬN GỬI" Height="38" Background="#2196F3" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="btnConfirmSend_Click"/>
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Grid.Row="2" Columns="2" Margin="0,15,0,0">
                                    <Button x:Name="btnTabStatus" Content="TRẠNG THÁI" Height="35" Margin="0,0,3,0" 
                        Background="White" Foreground="#2196F3" BorderBrush="#2196F3" 
                        BorderThickness="1" FontWeight="SemiBold" FontSize="11" Click="btnModeStatus_Click"/>
                                    <Button x:Name="btnTabAdd" Content="THÊM MỚI" Height="35" Margin="3,0,0,0" 
                        Background="White" Foreground="#2196F3" BorderBrush="#2196F3" 
                        BorderThickness="1" FontWeight="SemiBold" FontSize="11" Click="btnModeAdd_Click"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Danh sách -->
        <ScrollViewer Grid.Row="1" Margin="12">
            <ItemsControl x:Name="MemberList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,6" Background="White" CornerRadius="12"
                                Padding="14" MouseRightButtonDown="MemberCard_RightClick">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="44" Height="44"
                                        CornerRadius="22" Background="#1976D2">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               Foreground="White" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Tên + vai trò -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding RoleDisplay}" FontSize="12" Foreground="#757575"/>
                                </StackPanel>

                                <!-- Trạng thái -->
                                <Border Grid.Column="2" CornerRadius="12" Padding="10,4"
                                        Background="{Binding StatusColor}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>