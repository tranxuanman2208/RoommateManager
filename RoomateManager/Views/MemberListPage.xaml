<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="RoommateManager.Views.MemberListPage"
      Title="Danh sách thành viên" Background="#F5F5F5" d:DesignHeight="454.442" d:DesignWidth="401.934">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1976D2">
            <Grid Margin="16,0">
                <TextBlock Text="Danh sách thành viên"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnAddMember" Content="+ Thêm"
                            Background="White" Foreground="#1976D2"
                            BorderThickness="0" Padding="12,6"
                            FontWeight="Bold" Click="BtnAddMember_Click"
                            Margin="0,0,5,0"/>

                    <Grid Margin="5,0,0,0">
                        <Button x:Name="btnNotification" Content="🔔 Thông báo"
            Background="White" Foreground="#1976D2"
            BorderThickness="0" Padding="12,6"
            FontWeight="Bold" Click="BtnNotification_Click"/>

                        <Border x:Name="BadgeBorder" 
            Visibility="Collapsed" 
            Background="Red" 
            CornerRadius="9" 
            MinWidth="18" Height="18" 
            HorizontalAlignment="Right" 
            VerticalAlignment="Top" 
            Margin="0,-4,-4,0"
            Panel.ZIndex="1"
            IsHitTestVisible="False">
                            <TextBlock x:Name="txtBadgeCount" 
                   Text="0" 
                   Foreground="White" 
                   FontSize="10" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   Padding="4,0,4,0"/>
                        </Border>
                    </Grid>
                    <Popup x:Name="NotificationPopup"
       PlacementTarget="{Binding ElementName=btnNotification}"
       Placement="Bottom"
       StaysOpen="False"
       AllowsTransparency="True">
                        <Border Background="White" CornerRadius="12" Width="320" Height="370" 
            BorderBrush="#2196F3" BorderThickness="1" Margin="0,5,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.15"/>
                            </Border.Effect>

                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="THÔNG BÁO" FontWeight="Bold" Foreground="#2196F3" 
                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" 
                        BorderBrush="Transparent" FontSize="16" Foreground="#999" 
                        Cursor="Hand" Click="btn_ClosePopup_Click"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <ScrollViewer x:Name="scrViewStatus" Visibility="Visible">
                                        <ItemsControl x:Name="lstNotifications">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#F2F2F2" BorderThickness="0,0,0,1" Background="Transparent" Padding="10,15">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Noidung}" TextWrapping="Wrap" 
                                                       FontSize="14" Foreground="#333" FontWeight="Medium"
                                                       Loaded="txtNoidung_Loaded"/>

                                                                <TextBlock Text="{Binding Ngaytb}" FontSize="11" 
                                                       Foreground="#AAA" Margin="0,6,0,0"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                                <Button Content="×" Background="Transparent" BorderBrush="Transparent" 
                                                    Foreground="black" FontSize="18" Cursor="Hand" 
                                                    HorizontalAlignment="Right" Margin="0,0,-5,10"
                                                    Click="btnDeleteNotification_Click"/>

                                                                <TextBlock Text="Lượt xem" FontSize="10" Foreground="#2196F3" 
                                                       Cursor="Hand" TextDecorations="Underline" 
                                                       HorizontalAlignment="Right" MouseDown="btnViewDetail_MouseDown"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel x:Name="stkAddNotification" Visibility="Collapsed">
                                        <TextBlock Text="Nội dung" FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtInputTB" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                                     Padding="10" BorderBrush="#EEE" BorderThickness="1" Margin="0,0,0,15"/>

                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Người nhận:" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="cboRecipient" Grid.Column="1" DisplayMemberPath="Ten" 
                                  SelectedValuePath="Id" Height="30"/>
                                        </Grid>

                                        <Button Content="XÁC NHẬN GỬI" Height="40" Background="#2196F3" Foreground="White" 
                                     FontWeight="Bold" BorderThickness="0" Click="btnConfirmSend_Click"/>
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Grid.Row="2" Columns="2" Margin="0,15,0,0">
                                    <Button x:Name="btnTabStatus" Content="DANH SÁCH" Height="38" Margin="0,0,4,0" 
                        Background="White" Foreground="#2196F3" BorderBrush="#2196F3" 
                        BorderThickness="1" FontWeight="SemiBold" Click="btnModeStatus_Click"/>
                                    <Button x:Name="btnTabAdd" Content="SOẠN TIN" Height="38" Margin="4,0,0,0" 
                        Background="White" Foreground="#2196F3" BorderBrush="#2196F3" 
                        BorderThickness="1" FontWeight="SemiBold" Click="btnModeAdd_Click"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="12">
            <ItemsControl x:Name="MemberList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,6" Background="White" CornerRadius="12"
                                Padding="14" MouseRightButtonDown="MemberCard_RightClick">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="44" Height="44"
                                        CornerRadius="22" Background="#1976D2">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               Foreground="White" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding RoleDisplay}" FontSize="12" Foreground="#757575"/>
                                </StackPanel>

                                <Border Grid.Column="2" CornerRadius="12" Padding="10,4"
                                        Background="{Binding StatusColor}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>