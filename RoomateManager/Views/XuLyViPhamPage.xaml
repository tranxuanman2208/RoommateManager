<Page x:Class="RoommateManager.Views.XuLyViPhamPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Xử lý vi phạm">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUẢN LÝ VI PHẠM &amp; KỶ LUẬT" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="#F8F9F9" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#D5DBDB" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Người vi phạm:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cbThanhVien" Width="150" DisplayMemberPath="Ten" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Nội dung vi phạm:" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNoiDung" Width="300" MaxLength="200" VerticalContentAlignment="Center" Height="30"/>
                </StackPanel>
                <Button x:Name="btnLuu" Content="＋ Ghi nhận" Click="btnLuu_Click" 
                        Background="#27AE60" Foreground="White" Width="120" Height="32" VerticalAlignment="Bottom" />
            </StackPanel>
        </Border>

        <ListView Grid.Row="2" x:Name="lstViPham" BorderThickness="1" BorderBrush="#BDC3C7">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Người vi phạm" DisplayMemberBinding="{Binding TenNguoiVP}" Width="150"/>
                    <GridViewColumn Header="Nội dung" DisplayMemberBinding="{Binding Noidung}" Width="250"/>
                    <GridViewColumn Header="Ngày ghi nhận" DisplayMemberBinding="{Binding Ngayxuly, StringFormat='dd/MM/yyyy'}" Width="120"/>
                    <GridViewColumn Header="Trạng thái" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnDone" Content="✔ Đã xử lý" Click="btnDone_Click" Margin="5,0" Background="#27AE60" Foreground="White" Padding="10,5"/>
            <Button x:Name="btnDelete" Content="🗑 Xóa" Click="btnDelete_Click" Margin="5,0" Background="#E74C3C" Foreground="White" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Page>