<Page x:Class="RoommateManager.Views.ThongTinCaNhanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Thông tin cá nhân" Background="White">

    <Grid Margin="30">
        <StackPanel MaxWidth="600" HorizontalAlignment="Center">
            <TextBlock Text="THÔNG TIN CÁ NHÂN" FontSize="24" FontWeight="Bold" 
                       Foreground="#1976D2" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Border BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Mã thành viên:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtId" Grid.Row="0" Grid.Column="1" IsReadOnly="True" BorderThickness="0" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="1" Content="Họ và tên:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtTen" Grid.Row="1" Grid.Column="1" IsReadOnly="True" BorderThickness="0,0,0,1" VerticalContentAlignment="Center"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="✏️" Background="Transparent" BorderThickness="0" Click="Edit_Click" Tag="txtTen"/>

                    <Label Grid.Row="2" Content="Ngày sinh:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpNs" Grid.Row="2" Grid.Column="1" IsEnabled="False" VerticalContentAlignment="Center"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="✏️" Background="Transparent" BorderThickness="0" Click="EditDate_Click"/>

                    <Label Grid.Row="3" Content="Số điện thoại:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtSdt" Grid.Row="3" Grid.Column="1" IsReadOnly="True" BorderThickness="0,0,0,1" VerticalContentAlignment="Center"/>
                    <Button Grid.Row="3" Grid.Column="2" Content="✏️" Background="Transparent" BorderThickness="0" Click="Edit_Click" Tag="txtSdt"/>

                    <Label Grid.Row="4" Content="Mã nhà:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtMaNha" Grid.Row="4" Grid.Column="1" IsReadOnly="True" BorderThickness="0,0,0,1" VerticalContentAlignment="Center"/>
                    <Button Grid.Row="4" Grid.Column="2" Content="✏️" Background="Transparent" BorderThickness="0" Click="Edit_Click" Tag="txtMaNha"/>

                    <Label Grid.Row="5" Content="Gmail:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtMail" Grid.Row="5" Grid.Column="1" IsReadOnly="True" BorderThickness="0,0,0,1" VerticalContentAlignment="Center"/>
                    <Button Grid.Row="5" Grid.Column="2" Content="✏️" Background="Transparent" BorderThickness="0" Click="EditGmail_Click"/>
                </Grid>
            </Border>

            <Button x:Name="btnLuu" Content="LƯU THAY ĐỔI" Margin="0,30,0,0" Height="45" 
                    Background="#2E7D32" Foreground="White" FontWeight="Bold" 
                    Click="btnLuu_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>