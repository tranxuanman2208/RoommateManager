<Page x:Class="RoomateManager.DangNhapPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Đăng Nhập">

    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">

            <TextBlock Text="🔑" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="ĐĂNG NHẬP HỆ THỐNG" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#1976D2"/>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Tên đăng nhập" VerticalAlignment="Center" FontSize="14"/>
                <TextBox x:Name="txtUser" Grid.Column="1" Height="35" 
                     VerticalContentAlignment="Center" Padding="5,0"/>
            </Grid>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Mật khẩu" VerticalAlignment="Center" FontSize="14"/>
                <PasswordBox x:Name="txtPass" Grid.Column="1" Height="35" 
                         VerticalContentAlignment="Center" Padding="5,0"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnDangNhap" Content="ĐĂNG NHẬP" Width="140" Height="45" Margin="10,0"
                    Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="14"
                    Cursor="Hand" BorderThickness="0" Click="btnDangNhap_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnHuy" Content="HỦY" Width="140" Height="45" Margin="10,0"
                    Background="#f44336" Foreground="White" FontWeight="Bold" FontSize="14"
                    Cursor="Hand" BorderThickness="0" Click="btnHuy_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>