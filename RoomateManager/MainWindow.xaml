<Window x:Class="RoommateManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roommate Manager" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ModernRegisterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF5722"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E64A19"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ModernLoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                            CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name ="MenuRow" Height="65"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

            <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="0,15,20,0">

                <Button x:Name="btnDangNhap" Click="DangNhap_Click"
                Margin="0,0,10,0" Cursor="Hand"
                Style="{StaticResource ModernLoginButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔑" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Đăng nhập" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnDangKy" Click="DangKy_Click"
                Cursor="Hand"
                Style="{StaticResource ModernRegisterButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Đăng ký" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border x:Name="Menu" IsEnabled="False" Grid.Row="1" Background="#1976D2" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnHome" Click="NavBtn_Click" Tag="Home"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Trang chủ" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" x:Name="BtnInvoice" Click="NavBtn_Click" Tag="Invoice"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hóa đơn" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <Button Grid.Column="2" x:Name="BtnChart" Click="NavBtn_Click" Tag="Chart" 
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Thống kê" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" x:Name="BtnTask" Click="NavBtn_Click" Tag="Task" 
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🧹" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Phân công" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" x:Name="BtnViolation" Click="NavBtn_Click" Tag="Violation" 
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⚖️" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Vi phạm" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="5" x:Name="BtnBaoCao" Click="NavBtn_Click" Tag="BaoCao"
        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📢" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Báo cáo" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="6" Click="NavBtn_Click" Tag="VatDung"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="20"/>
                        <TextBlock Text="Vật dụng" FontSize="10"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="7" Click="NavBtn_Click" Tag="Logout"
                    Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📤" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Đăng xuất" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>