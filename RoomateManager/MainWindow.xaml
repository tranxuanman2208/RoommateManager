<Window x:Class="RoommateManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roommate Manager" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>

        <Frame x:Name="MainFrame" Grid.Row="0" NavigationUIVisibility="Hidden"/>

        <Border Grid.Row="1" Background="#1976D2" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnHome" Click="NavBtn_Click" Tag="Home"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Trang chủ" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" x:Name="BtnInvoice" Click="NavBtn_Click" Tag="Invoice"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hóa đơn" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <Button Grid.Column="2" x:Name="BtnChart" Click="NavBtn_Click" Tag="Chart" 
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Thống kê" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" x:Name="BtnTask" Click="NavBtn_Click" Tag="Task" 
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🧹" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Phân công" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" x:Name="BtnViolation" Click="NavBtn_Click" Tag="Violation" 
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⚖️" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Vi phạm" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="5" x:Name="BtnBaoCao" Click="NavBtn_Click" Tag="BaoCao"
        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📢" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Báo cáo" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="6" Click="NavBtn_Click" Tag="VatDung"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="20"/>
                        <TextBlock Text="Vật dụng" FontSize="10"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="7" x:Name="BtnSettings" Click="NavBtn_Click" Tag="Settings"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cài đặt" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>