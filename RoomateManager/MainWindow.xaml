<!-- MainWindow.xaml -->
<Window x:Class="RoommateManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roommate Manager" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>

        <!-- Vùng nội dung chính -->
        <Frame x:Name="MainFrame" Grid.Row="0" NavigationUIVisibility="Hidden"/>

        <!-- Navigation Bar cố định dưới cùng -->
        <Border Grid.Row="1" Background="#1976D2" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Trang chủ -->
                <Button Grid.Column="0" x:Name="BtnHome" Click="NavBtn_Click" Tag="Home"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Trang chủ" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Hóa đơn (có badge) -->
                <Button Grid.Column="1" x:Name="BtnInvoice" Click="NavBtn_Click" Tag="Invoice"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hóa đơn" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <!-- Badge -->
                        <Border x:Name="BadgeInvoice" Background="Red" CornerRadius="8"
                                Width="16" Height="16" HorizontalAlignment="Right"
                                VerticalAlignment="Top" Margin="0,2,2,0">
                            <TextBlock x:Name="BadgeInvoiceText" Text="2"
                                       FontSize="9" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Lịch -->
                <Button Grid.Column="2" x:Name="BtnCalendar" Click="NavBtn_Click" Tag="Calendar"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📅" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Lịch" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Quỹ -->
                <Button Grid.Column="3" x:Name="BtnFund" Click="NavBtn_Click" Tag="Fund"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Quỹ" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Cài đặt -->
                <Button Grid.Column="4" x:Name="BtnSettings" Click="NavBtn_Click" Tag="Settings"
                        Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cài đặt" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>