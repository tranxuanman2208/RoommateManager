<Window x:Class="RoomateManager.MinhChungWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Báo cáo" Height="250" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="CHI TIẾT BÁO CÁO GỐC" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
            <TextBlock Text="Mã báo cáo:" FontWeight="SemiBold"/>
            <TextBlock x:Name="txtMaBC" Margin="0,0,0,10" Foreground="Blue"/>

            <TextBlock Text="Nội dung minh chứng:" FontWeight="SemiBold"/>
            <Border Background="#F2F4F4" Padding="10" CornerRadius="5" Margin="0,5">
                <TextBlock x:Name="txtNoiDungGoc" TextWrapping="Wrap" FontStyle="Italic"/>
            </Border>

            <Button Content="Đóng" Click="Button_Click" Width="80" HorizontalAlignment="Right" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>