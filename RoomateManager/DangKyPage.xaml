<Page x:Class="RoomateManager.DangKyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RoomateManager"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DangKyPage">

    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">

            <TextBlock Text="ĐĂNG KÝ THÀNH VIÊN" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#1976D2"/>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Tên đăng nhập" VerticalAlignment="Center"/>
                <TextBox x:Name="txtUser" Grid.Column="1" Height="26" VerticalContentAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Nhập mật khẩu" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPass" Grid.Column="1" Height="26" VerticalContentAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Nhập lại mật khẩu" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPassA" Grid.Column="1" Height="26" VerticalContentAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Nhập gmail" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMail" Grid.Column="1" Height="26" VerticalContentAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Nhập số điện thoại" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPhone" Grid.Column="1" Height="26" VerticalContentAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Nhập mã nhà" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMaNha" Grid.Column="1" Height="26" VerticalContentAlignment="Center"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button x:Name="btnDangKy" Content="Đăng ký" Width="100" Height="40" 
                        Margin="10,0" Click="btnDangKy_Click" Cursor="Hand"
                        Background="#1976D2" Foreground="White" BorderThickness="0"/>

                <Button x:Name="btnHuy" Content="Hủy" Width="100" Height="40" 
                        Margin="10,0" Click="btnHuy_Click" Cursor="Hand"
                        Background="#f44336" Foreground="White" BorderThickness="0"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>