<Page x:Class="RoomateManager.DangKyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RoomateManager"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DangKyPage">
    <Grid Margin="-22,10,10,0" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="28*"/>
            <ColumnDefinition Width="29*"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="txtUser" HorizontalAlignment="Left" Margin="337,48,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="276" Height="26" Grid.ColumnSpan="2"/>
        <Label Content="Tên đăng nhập" HorizontalAlignment="Left" Margin="196,48,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtPass" HorizontalAlignment="Left" Margin="337,105,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="276" Height="26" Grid.ColumnSpan="2"/>
        <Label Content="Nhập mật khẩu" HorizontalAlignment="Left" Margin="197,105,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtPassA" HorizontalAlignment="Left" Margin="337,162,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="276" Height="26" Grid.ColumnSpan="2"/>
        <Label Content="Nhập lại mật khẩu" HorizontalAlignment="Left" Margin="197,162,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtMail" HorizontalAlignment="Left" Margin="337,216,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="276" Height="26" Grid.ColumnSpan="2"/>
        <Label Content="Nhập gmail" HorizontalAlignment="Left" Margin="200,216,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtPhone" HorizontalAlignment="Left" Margin="337,260,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="276" Height="26" Grid.ColumnSpan="2"/>
        <Label Content="Nhập số điện thoại" HorizontalAlignment="Left" Margin="200,260,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnDangKy" Content="Đăng ký" HorizontalAlignment="Left" Margin="173,358,0,0" VerticalAlignment="Top" Height="47" Width="83" Click="btnDangKy_Click" RenderTransformOrigin="0.535,0.543"/>
        <Button x:Name="btnHuy" Content="Hủy" HorizontalAlignment="Left" Margin="145,358,0,0" VerticalAlignment="Top" Height="47" Width="78" Click="btnHuy_Click" Grid.Column="1"/>
        <TextBox x:Name="txtMaNha" HorizontalAlignment="Left" Margin="337,305,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="276" Height="26" Grid.ColumnSpan="2"/>
        <Label Content="Nhập mã nhà" HorizontalAlignment="Left" Margin="199,305,0,0" VerticalAlignment="Top"/>
    </Grid>
</Page>
