<Page x:Class="RoomateManager.BaoCaoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BaoCaoPage">

    <Grid Background="#F5F5F5">
        <TabControl Margin="10">
            <TabItem Header="Gửi Báo Cáo">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" MaxWidth="600" HorizontalAlignment="Stretch">
                        <TextBlock Text="GỬI BÁO CÁO VI PHẠM" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#E67E22" HorizontalAlignment="Center"/>

                        <TextBlock Text="Người báo cáo:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbNguoiBao" Height="35" Margin="0,0,0,15" DisplayMemberPath="TEN" SelectedValuePath="ID" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Tiêu đề vụ việc:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtTieuDe" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Mô tả chi tiết (Nêu rõ ai vi phạm):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtNoiDung" MinHeight="100" MaxHeight="200" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" AcceptsReturn="True"/>

                        <CheckBox x:Name="chkAnDanh" Content="Báo cáo ẩn danh" Margin="0,0,0,25" VerticalAlignment="Center"/>

                        <Button Content="GỬI BÁO CÁO" Click="btnGui_Click" Background="#E67E22" Foreground="White" Height="45" FontWeight="Bold" Cursor="Hand"/>
                        <Border Height="20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Bảng tin &amp; Xử lý" Selector.Selected="TabItem_Selected">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="lstBangTin">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Người báo" DisplayMemberBinding="{Binding DisplayName}" Width="100"/>
                                <GridViewColumn Header="Nội dung báo cáo" DisplayMemberBinding="{Binding NOIDUNG}" Width="320"/>
                                <GridViewColumn Header="Thời gian" DisplayMemberBinding="{Binding NGAYBC, StringFormat='dd/MM HH:mm'}" Width="100"/>
                                <GridViewColumn Header="Trạng thái" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border Grid.Row="1" Background="#EAEAEA" Padding="15,10" CornerRadius="5" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Chỉ định người vi phạm để phạt:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>

                            <ComboBox x:Name="cbChonNguoiVP" Width="180" Height="35" Margin="0,0,15,0" 
                                      DisplayMemberPath="TEN" SelectedValuePath="ID" VerticalContentAlignment="Center"/>

                            <Button x:Name="btnXacNhanPhat" Content="✔ XÁC NHẬN &amp; PHẠT" Click="btnXacNhanPhat_Click" 
                                    Padding="15,5" Background="#2980B9" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

                            <Button Content="Xóa" Click="btnXoa_Click" Margin="10,0,0,0"
                                    Padding="15,5" Background="#C0392B" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>